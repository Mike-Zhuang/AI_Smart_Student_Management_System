{
  "name": "management-assistant-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @ms/backend\" \"npm run dev -w @ms/frontend\"",
    "dev:backend": "npm run dev -w @ms/backend",
    "dev:frontend": "npm run dev -w @ms/frontend",
    "build": "npm run build -w @ms/backend && npm run build -w @ms/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
