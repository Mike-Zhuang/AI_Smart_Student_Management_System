NODE_ENV=production
HOST=0.0.0.0
PORT=4000
TRUST_PROXY=loopback

# 生产环境必须替换为高强度随机密钥
ACCESS_TOKEN_SECRET=please-change-this-access-secret
REFRESH_TOKEN_SECRET=please-change-this-refresh-secret
ACCOUNT_ARCHIVE_SECRET=please-change-this-archive-secret

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_DOMAIN=
COOKIE_SECURE=true
ALLOWED_ORIGINS=http://127.0.0.1:8082

READ_RATE_LIMIT_PER_MINUTE=240
WRITE_RATE_LIMIT_PER_MINUTE=120
AI_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=20
AUTH_RATE_LIMIT_PER_MINUTE=40
AUTH_RATE_LIMIT_IP_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_IP_MAX_ATTEMPTS=25
AUTH_RATE_LIMIT_USER_IP_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_USER_IP_MAX_ATTEMPTS=8
AUTH_LOCK_WINDOW_MINUTES=30
AUTH_LOCK_MAX_FAILURES=8
AUTH_LOCK_MINUTES=20
AUTH_MIN_SUBMIT_DELAY_MS=800
RISK_CHALLENGE_TTL_SECONDS=300

UPLOAD_MAX_BYTES=8388608
IMPORT_MAX_ROWS=3000
IMPORT_MAX_CELL_LENGTH=400
TEXT_FIELD_MAX_LENGTH=2000
AUDIT_QUERY_MAX_LIMIT=500

# 生产环境默认不要启用演示数据
ENABLE_DEMO_SEED=false
